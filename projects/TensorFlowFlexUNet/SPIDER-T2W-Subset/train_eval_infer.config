; train_eval_infer.config
; 2026/05/27 (C) antillia.com
; SPIDER-T2W-Subset Segmentation
[model]
model         = "TensorFlowFlexUNet"
generator     =  False

image_width    = 512
image_height   = 512
image_channels = 3
input_normalize = True
normalization  = False
num_classes    = 17
base_filters   = 16
base_kernels   = (11,11)
num_layers     = 8
dropout_rate   = 0.05
dilation       = (1,1)

; Model compilation parameters
optimizer       = "Adam"

learning_rate  = 0.00007
clipvalue      = 0.5

; Specify "categorical_crossentropy" function to loss
; for categoraized(one-hot-encoded) mask 
loss           = "categorical_crossentropy"
metrics        = ["dice_coef_multiclass"]

show_summary   = False

[dataset]
class_name    = "ImageCategorizedMaskDataset"

[train]
;epochs       = 50
epochs        = 100
batch_size    = 2

;steps_per_epoch  = 200
;validation_steps = 80

; EarlyStopping parameter
patience      = 10

metrics       = ["dice_coef_multiclass", "val_dice_coef_multiclass"]

model_dir     = "./models/"
eval_dir      = "./eval/"
images_dir    = "../../../dataset/SPIDER-T2W-Subset/train/images/"
masks_dir     = "../../../dataset/SPIDER-T2W-Subset/train/masks/"

create_backup  = False

; learning_rate_reducer callback parameter
learning_rate_reducer = True
reducer_factor     = 0.4
reducer_patience   = 4

; Model saving option
save_weights_only  = True

[valid]
images_dir = "../../../dataset/SPIDER-T2W-Subset/valid/images/"
masks_dir  = "../../../dataset/SPIDER-T2W-Subset/valid/masks/"

[test] 
images_dir = "../../../dataset/SPIDER-T2W-Subset/test/images/"
masks_dir  = "../../../dataset/SPIDER-T2W-Subset/test/masks/"

[infer] 
images_dir    = "./mini_test/images/"
output_dir    = "./mini_test_output/"

[infer3d] 
;Specify an images_dir of NIfTI or MHA files
images_dir    = "./mini_test_3d/images/"

output_dir    = "./mini_test_3d_output/"

slice_shape_order = "hwd"

;2026/05/07 Added the following line
slice_normalize   = True

slice_resize   = None
slice_rotation = None

mask_overlay  = True

video_fps        = 10
;video_fileformat  = ".mp4"
video_fileformat  = ".gif"

[image]
color_order = "RGB"

[mask]
mask_datatyoe    = "categorized"
mask_file_format = ".png"
;SPIDER rgb color map dict for 1+16 classes.
rgb_map = {(0,0,0):0, (255,0,0):1, (0,255,0):2, (0,0,255):3, (255,255,0):4, (0,255,255):5, (255,0,255):6, (128,40,40):7,(40, 128,40):8,\
        (40,40,128):9, (128,128,0):10, (0,128,128):11,(128,0,128):12, (40,40,40):13, (80,80, 80):14, (128,128,128):15, (255,255,255):16}

